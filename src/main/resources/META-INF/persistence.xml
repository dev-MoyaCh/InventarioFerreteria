<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <!--
        Esta unidad de persistencia es como el "contrato" entre tu código
        y la base de datos: qué Entity usar, dónde está la BD, y cómo comportarse.
    -->
    <persistence-unit name="inventarioPU" transaction-type="RESOURCE_LOCAL">

        <class>com.ferreteria.modelo.Producto</class>

        <properties>
            <!-- Conexión a MySQL: ajusta usuario/contraseña a los que usaste
                 al instalar MySQL Server -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/ferreteria?useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <!-- La contraseña NO va aquí: se inyecta desde ProductoDAO.java
                 usando una variable de entorno, para no subirla a GitHub. -->

            <!-- update: crea/actualiza las tablas automáticamente según las Entity.
                 Ideal para desarrollo; en producción se usa "validate" o migraciones. -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Muestra el SQL que genera Hibernate en consola (útil para aprender) -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
        </properties>
    </persistence-unit>

</persistence>
